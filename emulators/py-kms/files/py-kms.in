#!/bin/sh

# $FreeBSD:$
#
# PROVIDE: %%PORTNAME%%
# REQUIRE: DAEMON
# KEYWORD: shutdown

# Add the following lines to /etc/rc.conf to enable %%PORTNAME%%
# %%RCNAME%%_enable="YES"
#
# %%RCNAME%%_enable (bool):	Set to YES to enable %%PORTNAME%%
#								Default: NO
# %%RCNAME%%_user (str):		%%PORTNAME%% daemon user
#								Default: daemon
# %%RCNAME%%_group (str):		%%PORTNAME%% daemon group
#								Default: daemon
# %%RCNAME%%_kmsdb (str):		%%PORTNAME%% location of SQLite database
#								Default: %%KMS_DBDIR%%/pykms_database.db

. /etc/rc.subr

name="%%RCNAME%%"
rcvar=%%RCNAME%%_enable
load_rc_config "$name"

: ${%%RCNAME%%_enable:="NO"}
: ${%%RCNAME%%_user:="daemon"}
: ${%%RCNAME%%_group:="daemon"}
: ${%%RCNAME%%_ip:="0.0.0.0"}
: ${%%RCNAME%%_port:="1688"}
: ${%%RCNAME%%_kmsdb:="%%KMS_DBDIR%%/pykms_database.db"}

pidfile="%%KMS_RUNDIR%%/%%PORTNAME%%.pid"
logfile="%%KMS_LOGDIR%%/%%PORTNAME%%.log"

procname="%%PYTHON_CMD%%"
kms_script="%%PREFIX%%/share/py-kms/pykms_Server.py"
kms_logfile="%%KMS_LOGDIR%%/%%PORTNAME%%_srv.log"
command="/usr/sbin/daemon"
command_args="-f -p ${pidfile} -o ${logfile} -T ${name} -- ${procname} ${kms_script} ${%%RCNAME%%_ip} ${%%RCNAME%%_port} --logfile ${kms_logfile} --sqlite ${%%RCNAME%%_kmsdb} ${%%RCNAME%%_flags}"

start_precmd="${name}_prestart"

py_kms_prestart()
{
	install -d -o ${%%RCNAME%%_user} -g ${%%RCNAME%%_group} %%KMS_RUNDIR%% %%KMS_LOGDIR%% %%KMS_DBDIR%%
}

run_rc_command "$1"

